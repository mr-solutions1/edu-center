# ==============================================================================
# Edu-Core API - Production Environment Configuration Template
# ==============================================================================

# Server Configuration
NODE_ENV=production
PORT=5000

# Database Configuration (Local MongoDB with Replica Set enabled)
# Note: For production, a Single-Node Replica Set 'rs0' must be configured.
MONGO_URI=mongodb://127.0.0.1:27017/edu_core?replicaSet=rs0

# JWT Configuration (Secrets must be strong, unique random strings of at least 32 characters)
JWT_ACCESS_SECRET=your_super_secret_access_token_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# CORS & Security
# Comma-separated list of additional allowed origins (primarily for dev/fallback).
# Note: Root domain, www, alpha, and app subdomains are validated dynamically inside app.js.
CORS_ORIGIN=https://alpha.flowship.site,https://flowship.site,https://app.flowship.site,http://localhost:5173
# Shared domain for HttpOnly cookie authentication across subdomains
COOKIE_DOMAIN=.flowship.site

# Logging Configuration
LOG_LEVEL=info

# File Upload Configuration
# MAX_FILE_SIZE (in bytes) - default: 5242880 (5MB)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads

# Optional Notification Providers (Configure to enable SMS/WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Optional Email Configuration (Configure to enable automated email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
