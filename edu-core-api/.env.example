# Server Configuration
NODE_ENV=production
PORT=5000

# Database Configuration (MongoDB Atlas recommended for Cloud Hosting)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/edu_core?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/edu_core

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# CORS & Security
# For production: https://app.rakaninstitutekw.com
CORS_ORIGIN=https://app.rakaninstitutekw.com
COOKIE_DOMAIN=rakaninstitutekw.com

# Logging
LOG_LEVEL=info
