# Server Configuration
NODE_ENV=production
PORT=5000

# Database Configuration (Local MongoDB on VPS)
# Example: mongodb://127.0.0.1:27017/edu_core
MONGO_URI=mongodb://127.0.0.1:27017/edu_core

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# CORS & Security
# Multiple origins can be separated by commas
# For production: https://rakan.flowship.site
CORS_ORIGIN=https://rakan.flowship.site,http://localhost:5173
COOKIE_DOMAIN=.flowship.site

# Logging
LOG_LEVEL=info
