# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (MongoDB Atlas)
# قم بتغيير <password> بكلمة مرور قاعدة البيانات الخاصة بك
MONGO_URI=mongodb+srv://admin:admin123@cluster0.mongodb.net/edu_core?retryWrites=true&w=majority

# JWT Configuration (استخدم هذه القيم للتطوير المحلي)
JWT_ACCESS_SECRET=local_development_access_secret_key_32_chars_min
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=local_development_refresh_secret_key_32_chars_min
JWT_REFRESH_EXPIRES_IN=7d

# CORS & Security
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# Logging
LOG_LEVEL=debug
